# Copy to `.env` and fill in your values:
#   cp .env.example .env
#
# WARNING: `.env` is bundled into release APKs (see pubspec.yaml assets).
# Use production values only — never commit `.env` to git.

# --- Wallet / payments ---

# Reown AppKit (iOS + standard Android wallet connect)
# Not used on Solana Mobile Stack devices (Seeker/Saga use native MWA instead).
# https://dashboard.reown.com
REOWN_PROJECT_ID=your_reown_project_id_here

# Solana mainnet RPC for PRANA ring checkout.
# Use a production RPC (Helius, QuickNode, etc.) for release builds.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# --- Release build (Android) ---
#
# 1. Create dApp Store keystore (separate from Google Play):
#    keytool -genkey -v -keystore android/keystores/vyana-dappstore.keystore \
#      -alias vyana-dappstore -keyalg RSA -keysize 2048 -validity 10000
#
# 2. Configure signing:
#    cp android/key.properties.example android/key.properties
#    # Paste dappStore passwords in key.properties
#
# 3. Build signed dApp Store APK:
#    ./scripts/build-dapp-store-apk.sh
#
# Docs: https://docs.solanamobile.com/dapp-store/build-and-sign-an-apk
# Submit: https://publish.solanamobile.com