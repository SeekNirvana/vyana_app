<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="STATE OF BEING"
            android:textColor="#C9A227"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.12" />

        <TextView
            android:id="@+id/widget_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to check in"
            android:textColor="#6C766C"
            android:textSize="9sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:text="Let's check in"
        android:textColor="#F2F5F2"
        android:textSize="18sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Biomarker grid: 2 columns x 3 rows -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <LinearLayout
            android:id="@+id/bio0_cell"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView android:id="@+id/bio0_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#F2F5F2" android:textSize="15sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/bio0_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#8A948C" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bio1_cell"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView android:id="@+id/bio1_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#F2F5F2" android:textSize="15sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/bio1_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#8A948C" android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="9dp"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <LinearLayout
            android:id="@+id/bio2_cell"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView android:id="@+id/bio2_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#F2F5F2" android:textSize="15sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/bio2_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#8A948C" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bio3_cell"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView android:id="@+id/bio3_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#F2F5F2" android:textSize="15sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/bio3_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#8A948C" android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="9dp"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <LinearLayout
            android:id="@+id/bio4_cell"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView android:id="@+id/bio4_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#F2F5F2" android:textSize="15sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/bio4_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#8A948C" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bio5_cell"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView android:id="@+id/bio5_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#F2F5F2" android:textSize="15sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/bio5_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#8A948C" android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
